# NEXUS-ALPHA Environment Configuration
# Copy to .env and fill in real values — NEVER commit the .env file

# === Exchange API Keys ===
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# === LLM Providers ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Database ===
TIMESCALEDB_URL=postgresql+asyncpg://nexus:changeme@localhost:5432/nexus_alpha
REDIS_URL=redis://localhost:6379/0

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# === MLflow ===
MLFLOW_TRACKING_URI=http://localhost:5000

# === Observability ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# === OpenClaw ===
CRYPTOPANIC_API_TOKEN=

# === Vault ===
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# === General ===
ENVIRONMENT=development
LOG_LEVEL=INFO
TRADING_MODE=paper
MAX_NAV_ALLOCATION_PCT=0.20
