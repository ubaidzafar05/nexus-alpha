# NEXUS-ALPHA Free Edition — Environment Configuration
# Copy to .env and fill in real values — NEVER commit the .env file
# Total cost to fill this: $0.00/month

# ═══════════════════════════════════════════════════════════════════
# EXCHANGE API KEYS (free — for paper/live trading)
# ═══════════════════════════════════════════════════════════════════
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ═══════════════════════════════════════════════════════════════════
# FREE LLM STACK — replaces Anthropic Claude + OpenAI
# ═══════════════════════════════════════════════════════════════════

# Ollama — local LLM server (runs on Oracle Cloud free VM or localhost)
# No API key — just run: ollama pull qwen3:8b && ollama pull deepseek-r1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen3:8b
OLLAMA_FAST_MODEL=mistral:7b
OLLAMA_REASONING_MODEL=deepseek-r1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Groq — free cloud fallback (6,000 req/day, Llama-3.3-70b free)
# Register free at: https://console.groq.com
GROQ_API_KEY=

# FinBERT — enabled by default (downloads from HuggingFace on first run, free)
FINBERT_ENABLED=true

# Legacy fields — intentionally empty (no paid keys needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# DATABASE (self-hosted — free)
# ═══════════════════════════════════════════════════════════════════
DB_PASSWORD=nexus_dev_change_me
REDIS_PASSWORD=nexus_dev_change_me
TIMESCALEDB_URL=postgresql+asyncpg://nexus:nexus_dev_change_me@localhost:5432/nexus_alpha
REDIS_URL=redis://:nexus_dev_change_me@localhost:6379/0

# ═══════════════════════════════════════════════════════════════════
# KAFKA (self-hosted KRaft — no Zookeeper — free)
# ═══════════════════════════════════════════════════════════════════
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ═══════════════════════════════════════════════════════════════════
# ML INFRASTRUCTURE (self-hosted — free)
# ═══════════════════════════════════════════════════════════════════
MLFLOW_TRACKING_URI=http://localhost:5000
QDRANT_URL=http://localhost:6333

# ═══════════════════════════════════════════════════════════════════
# FREE DATA SOURCES
# ═══════════════════════════════════════════════════════════════════

# CryptoPanic — 50 calls/hour free. Register at: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_TOKEN=

# Etherscan — 5 calls/sec free. Register at: https://etherscan.io/register
ETHERSCAN_API_KEY=

# CoinGecko — 10k calls/month free. Register at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Glassnode — Tier 1 free (daily metrics). Register at: https://glassnode.com
GLASSNODE_API_KEY=

# Reddit PRAW — 60 req/min free. Register at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Dune Analytics — free SQL tier. Register at: https://dune.com/settings/api
DUNE_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# ALERTS — Telegram Bot (replaces PagerDuty — free forever)
# Setup: 1. Message @BotFather → /newbot → get token
#        2. Message @userinfobot → get your chat ID
# ═══════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════════
# FREQTRADE TRADING ENGINE
# ═══════════════════════════════════════════════════════════════════
FREQTRADE_JWT_SECRET=change_me_to_random_string
FREQTRADE_WS_TOKEN=change_me_to_random_string
FREQTRADE_API_PASSWORD=change_me_to_strong_password
CRAWL4AI_TOKEN=change_me_to_random_string

# ═══════════════════════════════════════════════════════════════════
# MONITORING
# ═══════════════════════════════════════════════════════════════════
GRAFANA_PASSWORD=admin_change_me
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ═══════════════════════════════════════════════════════════════════
# GENERAL
# ═══════════════════════════════════════════════════════════════════
ENVIRONMENT=development
LOG_LEVEL=INFO
TRADING_MODE=paper
MAX_NAV_ALLOCATION_PCT=0.20
