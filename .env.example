# NEXUS-ALPHA Free Edition — Environment Configuration
# Copy to .env and fill in real values — NEVER commit the .env file
# Optional: encrypt your local .env with scripts/encrypt-env.sh

# ═══════════════════════════════════════════════════════════════════
# EXCHANGE API KEYS (paper/live trading)
# ═══════════════════════════════════════════════════════════════════
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BYBIT_API_KEY=
BYBIT_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ═══════════════════════════════════════════════════════════════════
# FREE LLM STACK
# ═══════════════════════════════════════════════════════════════════
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen3:8b
OLLAMA_FAST_MODEL=mistral:7b
OLLAMA_REASONING_MODEL=deepseek-r1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
GROQ_API_KEY=
FINBERT_ENABLED=true
FINBERT_MODEL_NAME=ProsusAI/finbert

# Legacy placeholders — keep empty on free stack
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# DATABASE / CACHE
# ═══════════════════════════════════════════════════════════════════
DB_PASSWORD=changeme
REDIS_PASSWORD=changeme
TIMESCALEDB_URL=postgresql+asyncpg://nexus:changeme@localhost:5432/nexus_alpha
REDIS_URL=redis://:changeme@localhost:6379/0

# ═══════════════════════════════════════════════════════════════════
# STREAMING / VECTOR / MLOPS
# ═══════════════════════════════════════════════════════════════════
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MLFLOW_TRACKING_URI=http://localhost:5000
QDRANT_URL=http://localhost:6333

# ═══════════════════════════════════════════════════════════════════
# FREE DATA SOURCES
# ═══════════════════════════════════════════════════════════════════
CRYPTOPANIC_API_TOKEN=
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=
GLASSNODE_API_KEY=
DUNE_API_KEY=

# Reddit (preferred: authenticated script app; fallback works without these)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=nexus-alpha/1.0 by your_reddit_username
REDDIT_SUBREDDITS=CryptoCurrency,Bitcoin,ethereum,solana,CryptoMarkets,defi,CryptoMoonShots
REDDIT_POST_LIMIT=15

# ═══════════════════════════════════════════════════════════════════
# ALERTS / EXTERNAL SERVICES
# ═══════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FREQTRADE_JWT_SECRET=change-me
FREQTRADE_WS_TOKEN=change-me
FREQTRADE_API_PASSWORD=change-me
CRAWL4AI_TOKEN=

# ═══════════════════════════════════════════════════════════════════
# MONITORING
# ═══════════════════════════════════════════════════════════════════
GRAFANA_PASSWORD=change-me
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ═══════════════════════════════════════════════════════════════════
# GENERAL
# ═══════════════════════════════════════════════════════════════════
ENVIRONMENT=development
LOG_LEVEL=INFO
TRADING_MODE=paper
MAX_NAV_ALLOCATION_PCT=0.20
