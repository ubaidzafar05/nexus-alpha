[Unit]
Description=Nexus Alpha - Alertmanager to Telegram forwarder
After=network.target

[Service]
# Adjust User as appropriate for your host
User=azt
WorkingDirectory=/Users/azt/Desktop/Python/nexus-alpha/infra/monitoring/alertmanager
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/env python3 telegram_forwarder.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
