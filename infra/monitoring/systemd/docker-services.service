[Unit]
Description=Nexus Alpha - Docker compose services (monitoring)
After=docker.service

[Service]
User=azt
WorkingDirectory=/Users/azt/Desktop/Python/nexus-alpha/infra/monitoring
Environment=COMPOSE_HTTP_TIMEOUT=200
ExecStart=/usr/bin/env docker compose up --remove-orphans
ExecStop=/usr/bin/env docker compose down
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
