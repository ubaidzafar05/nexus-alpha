[Unit]
Description=Nexus Alpha - Prometheus metrics server
After=network.target

[Service]
User=azt
WorkingDirectory=/Users/azt/Desktop/Python/nexus-alpha/infra/monitoring
MemoryMax=512M
CPUQuota=50%
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/env python3 metrics_server.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
