{
  "max_open_trades": 5,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "timeframe": "1h",
  "dry_run": true,
  "dry_run_wallet": 10000,
  "cancel_open_orders_on_exit": false,
  "trading_mode": "spot",
  "margin_mode": "",

  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT",
      "SOL/USDT",
      "BNB/USDT",
      "ADA/USDT"
    ],
    "pair_blacklist": [
      "BNB/.*",
      ".*/BTC",
      "(.*)(DOWN|UP|BULL|BEAR)(/.*)"
    ]
  },

  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },

  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },

  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "market",
    "stoploss_on_exchange": false
  },

  "order_time_in_force": {
    "entry": "GTC",
    "exit": "GTC"
  },

  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],

  "telegram": {
    "enabled": true,
    "token": "${TELEGRAM_BOT_TOKEN}",
    "chat_id": "${TELEGRAM_CHAT_ID}",
    "notification_settings": {
      "status": "on",
      "warning": "on",
      "startup": "on",
      "entry": "on",
      "exit": "on",
      "entry_cancel": "on",
      "exit_cancel": "on",
      "protection_trigger": "on",
      "protection_trigger_global": "on"
    }
  },

  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "${FREQTRADE_JWT_SECRET}",
    "ws_token": "${FREQTRADE_WS_TOKEN}",
    "CORS_origins": [],
    "username": "nexus",
    "password": "${FREQTRADE_API_PASSWORD}"
  },

  "bot_name": "nexus-alpha-freqtrade",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  },

  "freqai": {
    "enabled": false,
    "model_save_type": "joblib",
    "train_period_days": 90,
    "backtest_period_days": 30,
    "identifier": "nexus_alpha_v1",
    "live_retrain_hours": 4,
    "expiry_hours": 0,
    "feature_parameters": {
      "include_timeframes": ["1h", "4h", "1d"],
      "include_corr_pairlist": ["BTC/USDT", "ETH/USDT"],
      "indicator_periods_candles": [14, 28, 50],
      "label_period_candles": 24,
      "include_shifted_candles": 3,
      "DI_threshold": 0.9,
      "weight_factor": 0.9,
      "principal_component_analysis": false,
      "use_SVM_to_remove_outliers": true
    },
    "data_split_parameters": {
      "test_size": 0.25,
      "random_state": 42
    },
    "model_training_parameters": {
      "n_estimators": 1000,
      "random_state": 42,
      "learning_rate": 0.02,
      "max_depth": 6
    }
  }
}
